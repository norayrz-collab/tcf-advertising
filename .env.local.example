# Session / auth
SESSION_SECRET=                # openssl rand -base64 32
APP_PASSWORD_HASH=              # bcrypt hash of the shared dashboard password.
                                 # In .env* files, escape every "$" as "\$" (Next.js's
                                 # dotenv-expand treats "$2b$10$..." as variable refs
                                 # otherwise). Not needed when set via Vercel's env UI.
ALLOWED_EMAILS=you@company.com,teammate@company.com
ADMIN_EMAILS=you@company.com

# Google Sheets
GOOGLE_SHEET_ID=1lMy9g3RpNmAVUpheww4a3_11xDGtOVmG3HDtGfhDUJQ
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=              # paste with literal \n for newlines, keep quoted

# Upstash Redis (snapshot store + refresh lock)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
